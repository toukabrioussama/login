<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #f0f2f5;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edunova.connexion.controllers.UserController">

    <!-- HAUT : titre -->
    <top>
        <HBox style="-fx-background-color: #6a0dad; -fx-padding: 15;">
            <Label text="Gestion des Utilisateurs"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- CENTRE -->
    <center>
        <VBox spacing="12" style="-fx-padding: 15;">

            <!-- Barre de recherche -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtRecherche"
                           promptText="Rechercher par nom, prenom ou email..."
                           prefWidth="350"
                           style="-fx-padding: 6;"/>
                <Button text="Rechercher"
                        onAction="#handleRecherche"
                        style="-fx-background-color: #6a0dad; -fx-text-fill: white; -fx-padding: 6 14;"/>
                <Button text="Tout afficher"
                        onAction="#handleActualiser"
                        style="-fx-background-color: #888888; -fx-text-fill: white; -fx-padding: 6 14;"/>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="tableUsers" prefHeight="280">
                <columns>
                    <TableColumn fx:id="colId"     text="ID"         prefWidth="45"/>
                    <TableColumn fx:id="colNom"    text="Nom"        prefWidth="120"/>
                    <TableColumn fx:id="colPrenom" text="Prenom"     prefWidth="120"/>
                    <TableColumn fx:id="colEmail"  text="Email"      prefWidth="200"/>
                    <TableColumn fx:id="colTel"    text="Telephone"  prefWidth="110"/>
                    <TableColumn fx:id="colRole"   text="Role"       prefWidth="110"/>
                    <TableColumn fx:id="colActif"  text="Actif"      prefWidth="60"/>
                </columns>
            </TableView>

            <!-- Formulaire -->
            <TitledPane text="Formulaire utilisateur" expanded="true">
                <GridPane hgap="12" vgap="10">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>

                    <!-- Ligne 0 : Nom / Prenom -->
                    <Label text="Nom *"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtNom" prefWidth="200"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Prenom *"
                           GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtPrenom" prefWidth="200"
                               GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                    <!-- Ligne 1 : Email / Telephone -->
                    <Label text="Email *"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEmail" prefWidth="200"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Telephone"
                           GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtTelephone" prefWidth="200"
                               GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                    <!-- Ligne 2 : Mot de passe / Role -->
                    <Label text="Mot de passe"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="txtPassword" prefWidth="200"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Role *"
                           GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                    <ComboBox fx:id="cbRole" prefWidth="200"
                              promptText="Selectionner un role"
                              GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                    <!-- Ligne 3 : Actif -->
                    <Label text="Compte actif"
                           GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <CheckBox fx:id="chkActif" selected="true"
                              GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <!-- Ligne 4 : Boutons -->
                    <HBox spacing="10"
                          GridPane.rowIndex="4" GridPane.columnIndex="0"
                          GridPane.columnSpan="4">
                        <Button text="Ajouter"
                                onAction="#handleAjouter"
                                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-pref-width: 130;"/>
                        <Button text="Modifier"
                                onAction="#handleModifier"
                                style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-pref-width: 130;"/>
                        <Button text="Supprimer"
                                onAction="#handleSupprimer"
                                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-pref-width: 130;"/>
                        <Button text="Vider"
                                onAction="#handleVider"
                                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-pref-width: 130;"/>
                    </HBox>

                </GridPane>
            </TitledPane>

        </VBox>
    </center>

</BorderPane>