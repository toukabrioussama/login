<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="350" prefWidth="420" spacing="15" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edunova.connexion.controllers.ForgotPasswordController">

    <!-- Titre -->
    <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #6a0dad;" text="Mot de passe oublié" textFill="#dd7812">
      <font>
         <Font name="Aparajita Bold Italic" size="18.0" />
      </font></Label>

    <Label style="-fx-font-size: 13; -fx-text-fill: #555555;" text="Entrez votre email pour réinitialiser votre mot de passe." wrapText="true" />

    <!-- Etape 1 : Email -->
    <VBox fx:id="etape1" spacing="10">
        <Label style="-fx-font-weight: bold;" text="Adresse email *" />
        <TextField fx:id="txtEmail" prefWidth="350" promptText="email@example.com">
         <font>
            <Font size="14.0" />
         </font></TextField>
        <Button onAction="#handleVerifierEmail" prefWidth="350" style="-fx-background-color: #6a0dad; -fx-text-fill: white;                        -fx-font-size: 14; -fx-padding: 8; -fx-cursor: hand;" text="Verifier l'email" />
    </VBox>

    <!-- Etape 2 : Nouveau mot de passe (caché au départ) -->
    <VBox fx:id="etape2" managed="false" spacing="10" visible="false">
        <Label fx:id="lblEmailConfirm" style="-fx-text-fill: #28a745; -fx-font-weight: bold;" />
        <Label style="-fx-font-weight: bold;" text="Nouveau mot de passe *" />
        <PasswordField fx:id="txtNouveauMdp" prefWidth="350" promptText="Minimum 6 caractères" />
        <Label style="-fx-font-weight: bold;" text="Confirmer le mot de passe *" />
        <PasswordField fx:id="txtConfirmMdp" prefWidth="350" promptText="Répétez le mot de passe" />
        <Button onAction="#handleReinitialiser" prefWidth="350" style="-fx-background-color: #28a745; -fx-text-fill: white;                        -fx-font-size: 14; -fx-padding: 8; -fx-cursor: hand;" text="Réinitialiser le mot de passe" />
    </VBox>

    <!-- Bouton retour -->
    <Button onAction="#handleRetour" prefWidth="350" style="-fx-background-color: transparent; -fx-text-fill: #6a0dad;                    -fx-underline: true; -fx-cursor: hand;" text="Retour à la connexion" />

</VBox>
