<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edunova.connexion.controllers.PhonePickerController"
      prefWidth="420" prefHeight="540" spacing="0"
      style="-fx-background-color: white;
             -fx-background-radius: 16;">

    <!-- ══ HEADER ══ -->
    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #7c3aed;
                 -fx-background-radius: 16 16 0 0;
                 -fx-padding: 18 20;">
        <Label text="📞"
               style="-fx-font-size: 22;"/>
        <VBox style="-fx-padding: 0 0 0 12;">
            <Label text="Sélectionner un pays"
                   style="-fx-font-size: 15;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
            <Label text="Choisissez votre indicatif téléphonique"
                   style="-fx-font-size: 11;
                          -fx-text-fill: rgba(255,255,255,0.75);"/>
        </VBox>
    </HBox>

    <!-- ══ CONTENU ══ -->
    <VBox spacing="12"
          style="-fx-padding: 18 20;">

        <!-- Recherche -->
        <TextField fx:id="txtRecherchePays"
                   promptText="🔍  Rechercher un pays..."
                   style="-fx-background-color: #f8fafc;
                          -fx-text-fill: #1e293b;
                          -fx-prompt-text-fill: #94a3b8;
                          -fx-background-radius: 10;
                          -fx-padding: 10 14;
                          -fx-border-color: #e2e8f0;
                          -fx-border-radius: 10;
                          -fx-border-width: 1.5;
                          -fx-font-size: 13;"/>

        <!-- Liste pays -->
        <ListView fx:id="listePays"
                  prefHeight="220"
                  style="-fx-background-color: #f8fafc;
                         -fx-border-color: #e2e8f0;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-font-size: 13;"/>

        <!-- Pays sélectionné -->
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color: #f5f3ff;
                     -fx-background-radius: 10;
                     -fx-padding: 12 15;
                     -fx-border-color: #7c3aed;
                     -fx-border-radius: 10;
                     -fx-border-width: 1;">
            <Label text="Pays :"
                   style="-fx-font-size: 12;
                          -fx-text-fill: #64748b;"/>
            <Label fx:id="lblPaysSel"
                   text="🇹🇳 Tunisie"
                   style="-fx-font-size: 13;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1e293b;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblCodeSel"
                   text="+216"
                   style="-fx-font-size: 16;
                          -fx-font-weight: bold;
                          -fx-text-fill: #7c3aed;
                          -fx-background-color: #ede9fe;
                          -fx-background-radius: 6;
                          -fx-padding: 4 10;"/>
        </HBox>

        <!-- Numéro -->
        <VBox spacing="5">
            <Label text="Numéro de téléphone"
                   style="-fx-font-size: 12;
                          -fx-font-weight: bold;
                          -fx-text-fill: #374151;"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <!-- Code pays fixe -->
                <StackPane style="-fx-background-color: #f5f3ff;
                                  -fx-background-radius: 8;
                                  -fx-border-color: #7c3aed;
                                  -fx-border-radius: 8;
                                  -fx-border-width: 1.5;
                                  -fx-padding: 10 12;"
                           alignment="CENTER">
                    <Label fx:id="lblCodeSel2"
                           style="-fx-font-size: 13;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #7c3aed;"/>
                </StackPane>
                <!-- Champ numéro -->
                <TextField fx:id="txtNumero"
                           HBox.hgrow="ALWAYS"
                           promptText="22 123 456"
                           style="-fx-background-color: #f8fafc;
                                  -fx-text-fill: #1e293b;
                                  -fx-prompt-text-fill: #94a3b8;
                                  -fx-background-radius: 8;
                                  -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8;
                                  -fx-border-width: 1.5;
                                  -fx-padding: 10 12;
                                  -fx-font-size: 13;"/>
            </HBox>
            <Label fx:id="errNumero" text=""
                   style="-fx-text-fill: #ef4444;
                          -fx-font-size: 11;"/>
        </VBox>

        <!-- Boutons -->
        <HBox spacing="10">
            <Button text="Annuler"
                    onAction="#handleAnnuler"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-background-color: #f1f5f9;
                           -fx-text-fill: #64748b;
                           -fx-font-size: 13;
                           -fx-background-radius: 10;
                           -fx-padding: 11;
                           -fx-border-color: #e2e8f0;
                           -fx-border-radius: 10;
                           -fx-border-width: 1.5;
                           -fx-cursor: hand;"/>
            <Button text="✅ Confirmer"
                    onAction="#handleConfirmer"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-background-color: #7c3aed;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 13;
                           -fx-background-radius: 10;
                           -fx-padding: 11;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian,
                                       #7c3aed55,10,0,0,3);"/>
        </HBox>
    </VBox>
</VBox>