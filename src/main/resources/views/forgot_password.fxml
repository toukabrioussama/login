<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edunova.connexion.controllers.ForgotPasswordController"
           prefWidth="480" prefHeight="640"
           style="-fx-background-color: #0f0f1a;">

    <!-- Fond décoratif -->
    <StackPane style="-fx-background-color: transparent;">
        <Label text=""
               style="-fx-background-color: #7c3aed22;
                      -fx-background-radius: 50;
                      -fx-min-width: 300; -fx-min-height: 300;
                      -fx-max-width: 300; -fx-max-height: 300;
                      -fx-translate-x: 160; -fx-translate-y: -120;"/>
        <Label text=""
               style="-fx-background-color: #0ea5e911;
                      -fx-background-radius: 50;
                      -fx-min-width: 200; -fx-min-height: 200;
                      -fx-max-width: 200; -fx-max-height: 200;
                      -fx-translate-x: -150; -fx-translate-y: 150;"/>
    </StackPane>

    <!-- Carte principale -->
    <VBox spacing="0" alignment="TOP_CENTER"
          maxWidth="420"
          style="-fx-background-color: #1a1a2e;
                 -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian,
                             rgba(0,0,0,0.5),30,0,0,10);">

        <!-- ══ HEADER ══ -->
        <VBox alignment="CENTER" spacing="10"
              style="-fx-padding: 35 30 18 30;
                     -fx-background-color: #1a1a2e;
                     -fx-background-radius: 20 20 0 0;">

            <!-- Icône cadenas -->
            <StackPane style="-fx-background-color: #2d1b69;
                              -fx-background-radius: 50;
                              -fx-min-width: 70; -fx-min-height: 70;
                              -fx-max-width: 70; -fx-max-height: 70;"
                       alignment="CENTER">
                <Label text="🔐" style="-fx-font-size: 32;"/>
            </StackPane>

            <!-- Titre -->
            <Label text="Mot de passe oublié"
                   style="-fx-font-size: 21; -fx-font-weight: bold;
                          -fx-text-fill: #e2e8f0;
                          -fx-padding: 4 0 0 0;"/>

            <!-- Sous-titre -->
            <Label text="Réinitialisez votre accès en quelques étapes"
                   style="-fx-font-size: 12; -fx-text-fill: #64748b;
                          -fx-wrap-text: true;
                          -fx-text-alignment: center;"
                   maxWidth="300"/>

            <!-- Ligne décorative -->
            <HBox alignment="CENTER" spacing="4"
                  style="-fx-padding: 4 0 0 0;">
                <Region prefWidth="40" prefHeight="3"
                        style="-fx-background-color: #2d2d4e;
                               -fx-background-radius: 2;"/>
                <Region prefWidth="50" prefHeight="3"
                        style="-fx-background-color: #7c3aed;
                               -fx-background-radius: 2;"/>
                <Region prefWidth="40" prefHeight="3"
                        style="-fx-background-color: #2d2d4e;
                               -fx-background-radius: 2;"/>
            </HBox>
        </VBox>

        <!-- ══ INDICATEUR ÉTAPES ══ -->
        <HBox alignment="CENTER" spacing="8"
              style="-fx-padding: 12 30 12 30;
                     -fx-background-color: #1a1a2e;">

            <!-- Étape 1 -->
            <StackPane style="-fx-background-color: #7c3aed;
                              -fx-background-radius: 50;
                              -fx-min-width: 30; -fx-min-height: 30;
                              -fx-max-width: 30; -fx-max-height: 30;"
                       alignment="CENTER">
                <Label text="1"
                       style="-fx-font-size: 13; -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
            </StackPane>
            <Label text="Vérification"
                   style="-fx-font-size: 11; -fx-text-fill: #7c3aed;
                          -fx-font-weight: bold;"/>

            <!-- Ligne -->
            <Region prefWidth="35"
                    style="-fx-background-color: #2d2d4e;
                           -fx-pref-height: 2; -fx-max-height: 2;"/>

            <!-- Étape 2 -->
            <StackPane fx:id="etapeCircle2"
                       style="-fx-background-color: #2d2d4e;
                              -fx-background-radius: 50;
                              -fx-min-width: 30; -fx-min-height: 30;
                              -fx-max-width: 30; -fx-max-height: 30;"
                       alignment="CENTER">
                <Label fx:id="lblEtape2Num" text="2"
                       style="-fx-font-size: 13; -fx-font-weight: bold;
                              -fx-text-fill: #e2e8f0;"/>
            </StackPane>
            <Label fx:id="lblEtape2Txt" text="Réinitialisation"
                   style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
        </HBox>

        <!-- Séparateur -->
        <Region style="-fx-background-color: #2d2d4e;
                       -fx-pref-height: 1;"/>

        <!-- ══ CONTENU ══ -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-padding: 20 30 15 30;" spacing="0">

            <!-- ── ÉTAPE 1 : Email ── -->
            <VBox fx:id="etape1" spacing="12">

                <Label text="Entrez votre adresse email"
                       style="-fx-font-size: 14; -fx-font-weight: bold;
                              -fx-text-fill: #e2e8f0;"/>
                <Label text="Nous allons vérifier si votre compte existe."
                       style="-fx-font-size: 12; -fx-text-fill: #64748b;
                              -fx-wrap-text: true;"/>

                <VBox spacing="6">
                    <Label text="Adresse email"
                           style="-fx-font-size: 12;
                                  -fx-text-fill: #94a3b8;"/>
                    <TextField fx:id="txtEmail"
                               promptText="email@edunova.com"
                               style="-fx-background-color: #0f0f1a;
                                      -fx-text-fill: #e2e8f0;
                                      -fx-prompt-text-fill: #475569;
                                      -fx-background-radius: 10;
                                      -fx-padding: 12 15;
                                      -fx-border-color: #2d2d4e;
                                      -fx-border-radius: 10;
                                      -fx-font-size: 13;"/>
                    <Label fx:id="errEmail" text=""
                           style="-fx-text-fill: #f87171;
                                  -fx-font-size: 11;"/>
                </VBox>

                <Region prefHeight="5"/>

                <Button text="Vérifier mon compte"
                        onAction="#handleVerifierEmail"
                        maxWidth="Infinity"
                        style="-fx-background-color: #7c3aed;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14;
                               -fx-background-radius: 10;
                               -fx-padding: 13;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian,
                                           #7c3aed88,15,0,0,4);"/>
            </VBox>

            <!-- ── ÉTAPE 2 : Nouveau MDP ── -->
            <VBox fx:id="etape2" spacing="0"
                  visible="false" managed="false">

                <!-- Badge compte trouvé -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: #052e1a;
                             -fx-background-radius: 10;
                             -fx-padding: 10 15;
                             -fx-border-color: #10b981;
                             -fx-border-radius: 10;
                             -fx-border-width: 1;">
                    <Label text="✅" style="-fx-font-size: 14;"/>
                    <VBox spacing="2">
                        <Label text="Compte trouvé !"
                               style="-fx-font-size: 12;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #34d399;"/>
                        <Label fx:id="lblEmailConfirm" text=""
                               style="-fx-font-size: 11;
                                      -fx-text-fill: #10b981;"/>
                    </VBox>
                </HBox>

                <Region prefHeight="14"/>

                <Label text="Choisissez un nouveau mot de passe"
                       style="-fx-font-size: 14; -fx-font-weight: bold;
                              -fx-text-fill: #e2e8f0;"/>

                <Region prefHeight="14"/>

                <!-- Nouveau MDP -->
                <VBox spacing="5">
                    <Label text="Nouveau mot de passe"
                           style="-fx-font-size: 12;
                                  -fx-text-fill: #94a3b8;"/>
                    <PasswordField fx:id="txtNouveauMdp"
                                   promptText="Minimum 6 caractères"
                                   style="-fx-background-color: #0f0f1a;
                                          -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #475569;
                                          -fx-background-radius: 10;
                                          -fx-padding: 12 15;
                                          -fx-border-color: #2d2d4e;
                                          -fx-border-radius: 10;
                                          -fx-font-size: 13;"/>
                    <Label fx:id="errNouveauMdp" text=""
                           style="-fx-text-fill: #f87171;
                                  -fx-font-size: 11;"/>
                </VBox>

                <!-- Jauge force MDP -->
                <VBox spacing="4"
                      style="-fx-padding: 6 0 0 0;">
                    <Label fx:id="lblForceMdp" text=""
                           style="-fx-font-size: 11;"/>
                    <HBox spacing="4">
                        <Region fx:id="force1" prefHeight="4"
                                HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #2d2d4e;
                                       -fx-background-radius: 2;"/>
                        <Region fx:id="force2" prefHeight="4"
                                HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #2d2d4e;
                                       -fx-background-radius: 2;"/>
                        <Region fx:id="force3" prefHeight="4"
                                HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #2d2d4e;
                                       -fx-background-radius: 2;"/>
                        <Region fx:id="force4" prefHeight="4"
                                HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #2d2d4e;
                                       -fx-background-radius: 2;"/>
                    </HBox>
                </VBox>

                <!-- Espace réduit entre les deux champs -->
                <Region prefHeight="8"/>

                <!-- Confirmer MDP -->
                <VBox spacing="5">
                    <Label text="Confirmer le mot de passe"
                           style="-fx-font-size: 12;
                                  -fx-text-fill: #94a3b8;"/>
                    <PasswordField fx:id="txtConfirmMdp"
                                   promptText="Répétez le mot de passe"
                                   style="-fx-background-color: #0f0f1a;
                                          -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #475569;
                                          -fx-background-radius: 10;
                                          -fx-padding: 12 15;
                                          -fx-border-color: #2d2d4e;
                                          -fx-border-radius: 10;
                                          -fx-font-size: 13;"/>
                    <Label fx:id="errConfirmMdp" text=""
                           style="-fx-text-fill: #f87171;
                                  -fx-font-size: 11;"/>
                </VBox>

                <!-- Espace avant bouton -->
                <Region prefHeight="20"/>

                <!-- Bouton réinitialiser -->
                <Button text="Réinitialiser le mot de passe"
                        onAction="#handleReinitialiser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #059669;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14;
                               -fx-background-radius: 10;
                               -fx-padding: 13;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian,
                                           #10b98188,15,0,0,4);"/>
            </VBox>
        </VBox>

        <!-- ══ FOOTER RETOUR ══ -->
        <HBox alignment="CENTER"
              style="-fx-padding: 20 30 28 30;
                     -fx-border-color: #2d2d4e transparent
                                       transparent transparent;
                     -fx-border-width: 1 0 0 0;">
            <Button text="← Retour à la connexion"
                    onAction="#handleRetour"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #7c3aed;
                           -fx-font-size: 12;
                           -fx-underline: true;
                           -fx-cursor: hand;
                           -fx-padding: 5;"/>
        </HBox>
    </VBox>
</StackPane>