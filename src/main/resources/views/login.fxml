<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edunova.connexion.controllers.LoginController"
      prefWidth="980" prefHeight="660">

   <!-- ══ SIDEBAR GAUCHE ══ -->
   <VBox prefWidth="320" prefHeight="660"
         alignment="CENTER"
         style="-fx-background-color: #6d28d9;
                 -fx-padding: 40 28;">

      <VBox alignment="CENTER" spacing="10">
         <StackPane alignment="CENTER"
                    style="-fx-background-color: rgba(255,255,255,0.18);
                              -fx-background-radius: 50;
                              -fx-min-width: 82; -fx-min-height: 82;
                              -fx-max-width: 82; -fx-max-height: 82;">
            <Label text="🎓" style="-fx-font-size: 38;"/>
         </StackPane>
         <Label text="EduNova"
                style="-fx-font-size: 32; -fx-font-weight: bold;
                          -fx-text-fill: white;"/>
         <Label text="Plateforme de gestion scolaire"
                style="-fx-font-size: 12;
                          -fx-text-fill: rgba(255,255,255,0.75);
                          -fx-wrap-text: true;
                          -fx-text-alignment: center;"
                maxWidth="210"/>
      </VBox>

      <Region prefHeight="35"/>

      <VBox spacing="18">
         <HBox spacing="14" alignment="CENTER_LEFT">
            <StackPane alignment="CENTER"
                       style="-fx-background-color: rgba(255,255,255,0.18);
                                  -fx-background-radius: 10;
                                  -fx-min-width: 42; -fx-min-height: 42;
                                  -fx-max-width: 42; -fx-max-height: 42;">
               <Label text="📊" style="-fx-font-size: 19;"/>
            </StackPane>
            <VBox spacing="2">
               <Label text="Tableau de bord"
                      style="-fx-font-size: 13; -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
               <Label text="Statistiques en temps réel"
                      style="-fx-font-size: 11;
                                  -fx-text-fill: rgba(255,255,255,0.65);"/>
            </VBox>
         </HBox>

         <HBox spacing="14" alignment="CENTER_LEFT">
            <StackPane alignment="CENTER"
                       style="-fx-background-color: rgba(255,255,255,0.18);
                                  -fx-background-radius: 10;
                                  -fx-min-width: 42; -fx-min-height: 42;
                                  -fx-max-width: 42; -fx-max-height: 42;">
               <Label text="👥" style="-fx-font-size: 19;"/>
            </StackPane>
            <VBox spacing="2">
               <Label text="Gestion des utilisateurs"
                      style="-fx-font-size: 13; -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
               <Label text="Admins, enseignants, étudiants"
                      style="-fx-font-size: 11;
                                  -fx-text-fill: rgba(255,255,255,0.65);"/>
            </VBox>
         </HBox>

         <HBox spacing="14" alignment="CENTER_LEFT">
            <StackPane alignment="CENTER"
                       style="-fx-background-color: rgba(255,255,255,0.18);
                                  -fx-background-radius: 10;
                                  -fx-min-width: 42; -fx-min-height: 42;
                                  -fx-max-width: 42; -fx-max-height: 42;">
               <Label text="🔐" style="-fx-font-size: 19;"/>
            </StackPane>
            <VBox spacing="2">
               <Label text="Sécurité avancée"
                      style="-fx-font-size: 13; -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
               <Label text="Authentification sécurisée"
                      style="-fx-font-size: 11;
                                  -fx-text-fill: rgba(255,255,255,0.65);"/>
            </VBox>
         </HBox>
      </VBox>

      <Region VBox.vgrow="ALWAYS"/>

      <Label text="© 2026 EduNova · Tous droits réservés"
             style="-fx-font-size: 10;
                      -fx-text-fill: rgba(255,255,255,0.45);"/>
   </VBox>

   <!-- ══ PANNEAU DROIT ══ -->
   <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
               style="-fx-background: #f1f5f9;
                       -fx-background-color: #f1f5f9;
                       -fx-border-color: transparent;">
      <VBox alignment="CENTER"
            style="-fx-background-color: #f1f5f9;
                     -fx-padding: 28 45;"
            spacing="0">

         <!-- ════ FORMULAIRE CONNEXION ════ -->
         <VBox fx:id="panneauConnexion"
               style="-fx-background-color: white;
                         -fx-background-radius: 18;
                         -fx-padding: 34 36 26 36;
                         -fx-effect: dropshadow(gaussian,
                                     rgba(0,0,0,0.09),24,0,0,6);"
               spacing="0">

            <Label text="Bienvenue !"
                   style="-fx-font-size: 24; -fx-font-weight: bold;
                              -fx-text-fill: #1e293b;"/>
            <Label text="Connectez-vous à votre espace"
                   style="-fx-font-size: 13; -fx-text-fill: #64748b;
                              -fx-padding: 3 0 18 0;"/>

            <!-- Email -->
            <VBox spacing="5">
               <Label text="Adresse email"
                      style="-fx-font-size: 12; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;"/>
               <TextField fx:id="txtEmailO"
                          promptText="email@edunova.com"
                          style="-fx-background-color: #f8fafc;
                                      -fx-text-fill: #1e293b;
                                      -fx-prompt-text-fill: #94a3b8;
                                      -fx-background-radius: 10;
                                      -fx-padding: 11 14;
                                      -fx-border-color: #e2e8f0;
                                      -fx-border-radius: 10;
                                      -fx-border-width: 1.5;
                                      -fx-font-size: 13;"/>
               <Label fx:id="errLoginEmail" text=""
                      style="-fx-text-fill: #ef4444; -fx-font-size: 11;"/>
            </VBox>

            <Region prefHeight="8"/>

            <!-- Mot de passe -->
            <VBox spacing="5">
               <Label text="Mot de passe"
                      style="-fx-font-size: 12; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;"/>
               <PasswordField fx:id="txtPasswordO"
                              promptText="••••••••"
                              style="-fx-background-color: #f8fafc;
                                          -fx-text-fill: #1e293b;
                                          -fx-prompt-text-fill: #94a3b8;
                                          -fx-background-radius: 10;
                                          -fx-padding: 11 14;
                                          -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 10;
                                          -fx-border-width: 1.5;
                                          -fx-font-size: 13;"/>
               <Label fx:id="errLoginPassword" text=""
                      style="-fx-text-fill: #ef4444; -fx-font-size: 11;"/>
               <HBox alignment="CENTER_RIGHT">
                  <Label text="Mot de passe oublié ?"
                         onMouseClicked="#handleForgotPassword"
                         style="-fx-font-size: 11;
                                      -fx-text-fill: #7c3aed;
                                      -fx-cursor: hand;
                                      -fx-underline: true;"/>
               </HBox>
            </VBox>

            <Region prefHeight="8"/>



            <Region prefHeight="14"/>

            <!-- Bouton Se connecter -->
            <Button text="Se connecter"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color: #7c3aed;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14;
                               -fx-background-radius: 10;
                               -fx-padding: 13;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian,
                                           #7c3aed55,14,0,0,4);"/>

            <Region prefHeight="18"/>

            <!-- Séparateur OU -->
            <HBox alignment="CENTER" spacing="12">
               <Region HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #e2e8f0;
                                   -fx-pref-height: 1;"/>
               <Label text="ou continuez avec"
                      style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
               <Region HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #e2e8f0;
                                   -fx-pref-height: 1;"/>
            </HBox>

            <Region prefHeight="12"/>

            <!-- Bouton Google -->
            <Button text="  G   Continuer avec Google"
                    onAction="#handleGoogleLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color: white;
                               -fx-text-fill: #374151;
                               -fx-font-size: 13;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 11;
                               -fx-border-color: #e2e8f0;
                               -fx-border-radius: 10;
                               -fx-border-width: 1.5;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian,
                                           rgba(0,0,0,0.05),6,0,0,2);"/>

            <Region prefHeight="14"/>

            <HBox alignment="CENTER" spacing="5">
               <Label text="Pas encore de compte ?"
                      style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>
               <Label text="S'inscrire"
                      onMouseClicked="#handleShowInscription"
                      style="-fx-font-size: 12;
                                  -fx-text-fill: #7c3aed;
                                  -fx-font-weight: bold;
                                  -fx-cursor: hand;
                                  -fx-underline: true;"/>
            </HBox>
         </VBox>

         <!-- ════ FORMULAIRE INSCRIPTION ════ -->
         <VBox fx:id="panneauInscription"
               visible="false" managed="false"
               style="-fx-background-color: white;
                         -fx-background-radius: 18;
                         -fx-padding: 28 36 22 36;
                         -fx-effect: dropshadow(gaussian,
                                     rgba(0,0,0,0.09),24,0,0,6);"
               spacing="0">

            <Label text="Créer un compte"
                   style="-fx-font-size: 22; -fx-font-weight: bold;
                              -fx-text-fill: #1e293b;"/>
            <Label text="Rejoignez EduNova dès maintenant"
                   style="-fx-font-size: 12; -fx-text-fill: #64748b;
                              -fx-padding: 3 0 14 0;"/>

            <!-- Nom / Prénom -->
            <HBox spacing="14">
               <VBox HBox.hgrow="ALWAYS" spacing="4">
                  <Label text="Nom *"
                         style="-fx-font-size: 12; -fx-font-weight: bold;
                                      -fx-text-fill: #374151;"/>
                  <TextField fx:id="txtRegNom"
                             promptText="Nom de famille"
                             style="-fx-background-color: #f8fafc;
                                          -fx-text-fill: #1e293b;
                                          -fx-prompt-text-fill: #94a3b8;
                                          -fx-background-radius: 10;
                                          -fx-padding: 10 12;
                                          -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 10;
                                          -fx-border-width: 1.5;
                                          -fx-font-size: 12;"/>
                  <Label fx:id="errRegNom" text=""
                         style="-fx-text-fill: #ef4444; -fx-font-size: 10;"/>
               </VBox>
               <VBox HBox.hgrow="ALWAYS" spacing="4">
                  <Label text="Prénom *"
                         style="-fx-font-size: 12; -fx-font-weight: bold;
                                      -fx-text-fill: #374151;"/>
                  <TextField fx:id="txtRegPrenom"
                             promptText="Prénom"
                             style="-fx-background-color: #f8fafc;
                                          -fx-text-fill: #1e293b;
                                          -fx-prompt-text-fill: #94a3b8;
                                          -fx-background-radius: 10;
                                          -fx-padding: 10 12;
                                          -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 10;
                                          -fx-border-width: 1.5;
                                          -fx-font-size: 12;"/>
                  <Label fx:id="errRegPrenom" text=""
                         style="-fx-text-fill: #ef4444; -fx-font-size: 10;"/>
               </VBox>
            </HBox>

            <Region prefHeight="9"/>

            <!-- Email -->
            <VBox spacing="4">
               <Label text="Email *"
                      style="-fx-font-size: 12; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;"/>
               <TextField fx:id="txtRegEmail"
                          promptText="email@edunova.com"
                          style="-fx-background-color: #f8fafc;
                                      -fx-text-fill: #1e293b;
                                      -fx-prompt-text-fill: #94a3b8;
                                      -fx-background-radius: 10;
                                      -fx-padding: 10 12;
                                      -fx-border-color: #e2e8f0;
                                      -fx-border-radius: 10;
                                      -fx-border-width: 1.5;
                                      -fx-font-size: 12;"/>
               <Label fx:id="errRegEmail" text=""
                      style="-fx-text-fill: #ef4444; -fx-font-size: 10;"/>
            </VBox>

            <Region prefHeight="9"/>

            <!-- Téléphone avec dropdown inline -->
            <VBox spacing="5">
               <Label text="Téléphone"
                      style="-fx-font-size: 12; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;"/>
               <HBox spacing="8" alignment="CENTER_LEFT">
                  <Button fx:id="btnPaysReg"
                          text="🇹🇳  +216"
                          onAction="#handleToggleDropdownReg"
                          style="-fx-background-color: #f8fafc;
               -fx-text-fill: #374151;
               -fx-font-size: 13;
               -fx-font-weight: bold;
               -fx-background-radius: 10;
               -fx-border-color: #e2e8f0;
               -fx-border-radius: 10;
               -fx-border-width: 1.5;
               -fx-padding: 10 14;
               -fx-cursor: hand;
               -fx-min-width: 110;"/>
                  <TextField fx:id="txtRegTel"
                             HBox.hgrow="ALWAYS"
                             promptText="22 123 456"
                             style="-fx-background-color: #f8fafc;
                                          -fx-text-fill: #1e293b;
                                          -fx-prompt-text-fill: #94a3b8;
                                          -fx-background-radius: 10;
                                          -fx-padding: 10 12;
                                          -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 10;
                                          -fx-border-width: 1.5;
                                          -fx-font-size: 12;"/>
               </HBox>

               <!-- Dropdown inline -->
               <VBox fx:id="dropdownPaysReg"
                     visible="false" managed="false"
                     spacing="6"
                     style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #e2e8f0;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1.5;
                                 -fx-padding: 10;
                                 -fx-effect: dropshadow(gaussian,
                                             rgba(0,0,0,0.10),12,0,0,4);">
                  <TextField fx:id="txtRecherchePaysReg"
                             promptText="🔍  Rechercher un pays..."
                             style="-fx-background-color: #f8fafc;
                                          -fx-text-fill: #1e293b;
                                          -fx-prompt-text-fill: #94a3b8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 8 12;
                                          -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 8;
                                          -fx-border-width: 1.5;
                                          -fx-font-size: 12;"/>
                  <ScrollPane prefHeight="160" fitToWidth="true"
                              style="-fx-background: transparent;
                                           -fx-background-color: transparent;
                                           -fx-border-color: transparent;">
                     <VBox fx:id="listePaysReg" spacing="2"/>
                  </ScrollPane>
               </VBox>

               <Label fx:id="errRegTel" text=""
                      style="-fx-text-fill: #ef4444; -fx-font-size: 10;"/>
            </VBox>

            <Region prefHeight="9"/>

            <!-- Rôle -->
            <VBox spacing="4">
               <Label text="Rôle *"
                      style="-fx-font-size: 12; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;"/>
               <ComboBox fx:id="cbRegRole"
                         maxWidth="Infinity" prefWidth="99999"
                         promptText="Sélectionner votre rôle"
                         style="-fx-background-color: #f8fafc;
                                     -fx-background-radius: 10;
                                     -fx-border-color: #e2e8f0;
                                     -fx-border-radius: 10;
                                     -fx-border-width: 1.5;
                                     -fx-font-size: 12;"/>
               <Label fx:id="errRegRole" text=""
                      style="-fx-text-fill: #ef4444; -fx-font-size: 10;"/>
            </VBox>

            <Region prefHeight="9"/>

            <!-- Mot de passe / Confirmer -->
            <HBox spacing="14">
               <VBox HBox.hgrow="ALWAYS" spacing="4">
                  <Label text="Mot de passe *"
                         style="-fx-font-size: 12; -fx-font-weight: bold;
                                      -fx-text-fill: #374151;"/>
                  <PasswordField fx:id="txtRegPassword"
                                 promptText="Min. 6 car."
                                 style="-fx-background-color: #f8fafc;
                                              -fx-text-fill: #1e293b;
                                              -fx-prompt-text-fill: #94a3b8;
                                              -fx-background-radius: 10;
                                              -fx-padding: 10 12;
                                              -fx-border-color: #e2e8f0;
                                              -fx-border-radius: 10;
                                              -fx-border-width: 1.5;
                                              -fx-font-size: 12;"/>
                  <Label fx:id="errRegPassword" text=""
                         style="-fx-text-fill: #ef4444; -fx-font-size: 10;"/>
               </VBox>
               <VBox HBox.hgrow="ALWAYS" spacing="4">
                  <Label text="Confirmer *"
                         style="-fx-font-size: 12; -fx-font-weight: bold;
                                      -fx-text-fill: #374151;"/>
                  <PasswordField fx:id="txtRegConfirm"
                                 promptText="Répéter..."
                                 style="-fx-background-color: #f8fafc;
                                              -fx-text-fill: #1e293b;
                                              -fx-prompt-text-fill: #94a3b8;
                                              -fx-background-radius: 10;
                                              -fx-padding: 10 12;
                                              -fx-border-color: #e2e8f0;
                                              -fx-border-radius: 10;
                                              -fx-border-width: 1.5;
                                              -fx-font-size: 12;"/>
                  <Label fx:id="errRegConfirm" text=""
                         style="-fx-text-fill: #ef4444; -fx-font-size: 10;"/>
               </VBox>
            </HBox>

            <Region prefHeight="9"/>

            <!-- CGU -->
            <HBox spacing="8" alignment="CENTER_LEFT">
               <CheckBox fx:id="chkCgu" style="-fx-cursor: hand;"/>
               <Label text="J'accepte les conditions d'utilisation"
                      style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
            </HBox>
            <Label fx:id="errCgu" text=""
                   style="-fx-text-fill: #ef4444; -fx-font-size: 10;"/>

            <Region prefHeight="12"/>

            <Button text="Créer mon compte"
                    onAction="#handleInscription"
                    maxWidth="Infinity"
                    style="-fx-background-color: #7c3aed;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 13;
                               -fx-background-radius: 10;
                               -fx-padding: 12;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian,
                                           #7c3aed55,14,0,0,4);"/>

            <Region prefHeight="10"/>

            <HBox alignment="CENTER" spacing="5">
               <Label text="Déjà un compte ?"
                      style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>
               <Label text="Se connecter"
                      onMouseClicked="#handleShowConnexion"
                      style="-fx-font-size: 12;
                                  -fx-text-fill: #7c3aed;
                                  -fx-font-weight: bold;
                                  -fx-cursor: hand;
                                  -fx-underline: true;"/>
            </HBox>
         </VBox>
      </VBox>
   </ScrollPane>
</HBox>